NODE_ENV=production
PORT=4000

# Replace with your AAPanel PostgreSQL credentials and database name
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=tenant_default"

JWT_SECRET="change-this-to-a-long-random-secret-minimum-32-characters"
JWT_EXPIRES_IN="8h"

TENANT_ID=default
TENANT_SCHEMA=tenant_default

FRONTEND_URL=https://your-frontend-domain.com

# S3-compatible object storage (optional for Phase 1)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# SMTP / Email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
